# axon-lang .gitignore

# -----------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------
target/
Cargo.lock
**/*.rs.bk

# -----------------------------------------------------------------------
# C / CMake build artifacts
# -----------------------------------------------------------------------
build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.o
*.a
*.so
*.dylib
*.dll

# AXON compiled output
*.axb

# -----------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------
# LLVM artifacts
# -----------------------------------------------------------------------
*.bc
*.ll

# -----------------------------------------------------------------------
# Shared memory segments (runtime artifacts)
# -----------------------------------------------------------------------
/tmp/axon_*

# -----------------------------------------------------------------------
# Test artifacts
# -----------------------------------------------------------------------
testing/
coverage/
*.profraw
*.profdata

# -----------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------
*.log
logs/
